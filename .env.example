# Django Configuration
DEBUG=True
SECRET_KEY=your-django-secret-key-here
ALLOWED_HOSTS=localhost,127.0.0.1,backend
USE_SQLITE=False

# Database Configuration (for PostgreSQL with pgvector)
DB_NAME=studycommander
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db
DB_PORT=5432

# Redis & Celery Configuration
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1

# Gemini API Integration
# Get your key at https://aistudio.google.com/
GEMINI_API_KEY=your-google-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-pro
GEMINI_EMBEDDING_MODEL=text-embedding-004

# Seeding variables
STUDENT_EMAIL=student@domain.com
STUDENT_PASSWORD=your_secure_password

# Email Settings (Optional)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-email-app-password
DEFAULT_FROM_EMAIL=Study Commander AI <noreply@studycommander.ai>

# Frontend / CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
JWT_COOKIE_SAMESITE=Lax
JWT_COOKIE_SECURE=False
DOMAIN_NAME=localhost
NOTIFICATION_EMAIL=admin@domain.com
